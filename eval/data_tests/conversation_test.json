    {
      "test_id": "T10_double_yes_name_and_country",
      "category": "ambiguity",
      "input": {
        "turns": [
          {"user": "send 500 USD to Maria Chile via bank deposit"},
          {"user": "yes that's the name and yes Chile is the country"},
          {"user": "yes"}
        ]
      },
      "expected": {
        "tools_sequence": [
          ["update_state","clarify"],
          ["resolve_clarification","resolve_clarification","validate_transfer"],
          ["submit_transfer"]
        ],
        "task": {"should_complete": 1},
        "final_state": {
          "recipient_name": "Maria Chile",
          "country": "CL",
          "amount": 500.0,
          "currency": "USD",
          "delivery_method": "bank_deposit",
          "status": "done"
        },
        "ragas": {
          "reference_answers": [
            "Is 'Maria Chile' the recipient's full name?",
            "You're about to send 500 USD to Maria Chile in Chile via bank deposit. Confirm? (yes / no)",
            "Transfer of 500 USD to Maria Chile in Chile submitted successfully!"
          ]
        }
      }
    },

